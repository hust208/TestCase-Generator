# ============================================================
# TestCase Generator - 环境变量配置
# ============================================================
# 复制此文件为 .env 并填入实际值
# docker compose 会自动读取 .env 文件
# ============================================================

# ---- LLM API ----
LLM_API_URL=http://host.docker.internal:8000/v1/chat/completions

# ---- Embedding API ----
EMB_API_URL=http://host.docker.internal:8001/v1/embeddings

# ---- 知识库 API ----
KB_API_URL=http://jszsk.jieshun.cn:3000/openapi/chat

# ---- FastGPT API ----
FASTGPT_URL=http://host.docker.internal:3000
FASTGPT_API_KEY=fastgpt-your-api-key-here

# ---- 评测参数 ----
JUDGE_ROUNDS=3
MIN_SCORE=0.8
